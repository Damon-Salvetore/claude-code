# =====================================================
# Test 15: FFN backward — nvfp4_mode=3
# =====================================================
def test_ffn_mode3_backward():
    """Gradients flow through FFN with nvfp4_mode=3."""
    from arch.ffn import FeedForwardNetwork

    device = 'cuda' if torch.cuda.is_available() else 'cpu'
    torch.manual_seed(42)

    embed_dim, ffn_dim = 64, 192
    total_seq_len = 128

    ffn = FeedForwardNetwork(embed_dim, ffn_dim, nvfp4_mode=3).to(device)
    x = torch.randn(total_seq_len, embed_dim, dtype=torch.bfloat16, device=device, requires_grad=True)

    result = ffn(x)
    loss = result.float().sum()
    loss.backward()

    for name, param in ffn.named_parameters():
        assert param.grad is not None, f"No gradient for {name}"
        assert not torch.isnan(param.grad).any(), f"NaN gradient for {name}"
        assert not torch.isinf(param.grad).any(), f"Inf gradient for {name}"

    assert x.grad is not None, "No gradient for input"
    assert not torch.isnan(x.grad).any(), "NaN in input gradient"
    print("  PASS: FFN mode=3 backward gradients flow correctly")


# =====================================================
# Test 16: FFN mode=3 vs baseline — has quant noise
# =====================================================
def test_ffn_mode3_vs_baseline():
    """Mode=3 introduces quantization noise vs baseline."""
    from arch.ffn import FeedForwardNetwork

    device = 'cuda' if torch.cuda.is_available() else 'cpu'
    torch.manual_seed(42)

    embed_dim, ffn_dim = 64, 192
    total_seq_len = 128

    ffn_base = FeedForwardNetwork(embed_dim, ffn_dim, nvfp4_mode=0).to(device)
    ffn_mx = FeedForwardNetwork(embed_dim, ffn_dim, nvfp4_mode=3).to(device)
    ffn_mx.load_state_dict(ffn_base.state_dict())

    x = torch.randn(total_seq_len, embed_dim, dtype=torch.bfloat16, device=device)

    result_base = ffn_base(x)
    result_mx = ffn_mx(x)

    diff = (result_mx.float() - result_base.float()).abs()
    assert diff.max() > 0, "Mode=3 should introduce quantization noise vs baseline"
    rel_err = diff.mean() / (result_base.float().abs().mean() + 1e-8)
    assert rel_err < 0.5, f"Quantization error too large: rel_err={rel_err.item():.4f}"
    print(f"  PASS: Mode=3 vs baseline has quant noise (rel_err={rel_err.item():.4f})")


# =====================================================
# Test 17: FFN mode=3 vs mode=2 — different outputs
# =====================================================
def test_ffn_mode3_vs_mode2():
    """Mode=3 (W4A8) and mode=2 (W4A4) produce different outputs."""
    from arch.ffn import FeedForwardNetwork

    device = 'cuda' if torch.cuda.is_available() else 'cpu'
    torch.manual_seed(42)

    embed_dim, ffn_dim = 64, 192
    total_seq_len = 128

    ffn_nvfp4 = FeedForwardNetwork(embed_dim, ffn_dim, nvfp4_mode=2).to(device)
    ffn_mx = FeedForwardNetwork(embed_dim, ffn_dim, nvfp4_mode=3).to(device)
    # Same weights
    ffn_mx.load_state_dict(ffn_nvfp4.state_dict())

    x = torch.randn(total_seq_len, embed_dim, dtype=torch.bfloat16, device=device)

    result_nvfp4 = ffn_nvfp4(x)
    result_mx = ffn_mx(x)

    diff = (result_mx.float() - result_nvfp4.float()).abs()
    assert diff.max() > 0, "Mode=3 (W4A8) and mode=2 (W4A4) should produce different outputs"
    print(f"  PASS: Mode=3 vs mode=2 outputs differ (max_diff={diff.max().item():.6f})")


