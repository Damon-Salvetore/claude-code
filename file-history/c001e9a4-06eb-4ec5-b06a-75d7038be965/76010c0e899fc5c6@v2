    print("  PASS: MXFP4 multi-block quantization correct")


# =====================================================
# Test 6: MXFP8 fake quant basic correctness
# =====================================================
def test_mxfp8_basic():
    """MXFP8 should quantize to FP8 E4M3 levels with E8M0 scale."""
    from kernel.mxfp_quant import mxfp8_fake_quant, MXFP_BLOCK_SIZE

    device = 'cuda' if torch.cuda.is_available() else 'cpu'

    x = torch.randn(MXFP_BLOCK_SIZE, dtype=torch.float32, device=device) * 10.0
    result = mxfp8_fake_quant(x)

    assert result.shape == x.shape
    assert result.dtype == x.dtype
    assert not torch.isnan(result).any(), "NaN in MXFP8 output"
    assert not torch.isinf(result).any(), "Inf in MXFP8 output"

    # MXFP8 (FP8 E4M3, 448 levels) should be more precise than MXFP4 (16 levels)
    diff = (result - x).abs()
    rel_err = diff.mean() / (x.abs().mean() + 1e-8)
    assert rel_err < 0.1, f"MXFP8 relative error too large: {rel_err.item():.4f}"
    print(f"  PASS: MXFP8 basic correctness (rel_err={rel_err.item():.6f})")


# =====================================================
# Test 7: MXFP8 vs MXFP4 precision comparison
# =====================================================
def test_mxfp8_vs_mxfp4_precision():
    """MXFP8 (E4M3) should be much more precise than MXFP4 (E2M1)."""
    from kernel.mxfp_quant import mxfp4_fake_quant, mxfp8_fake_quant

    device = 'cuda' if torch.cuda.is_available() else 'cpu'
    torch.manual_seed(42)

    x = torch.randn(256, dtype=torch.float32, device=device) * 5.0

    result_fp4 = mxfp4_fake_quant(x)
    result_fp8 = mxfp8_fake_quant(x)

    err_fp4 = (result_fp4 - x).abs().mean()
    err_fp8 = (result_fp8 - x).abs().mean()

    assert err_fp8 < err_fp4, \
        f"MXFP8 should be more precise than MXFP4. FP8 err={err_fp8.item():.6f}, FP4 err={err_fp4.item():.6f}"
    print(f"  PASS: MXFP8 more precise than MXFP4 (FP8 err={err_fp8.item():.6f} < FP4 err={err_fp4.item():.6f})")


