# Test 8: STE gradient — MXFP4
# =====================================================
def test_mxfp4_ste_gradient():
    """MXFP4 gradients should pass through unchanged (pure STE)."""
    from kernel.mxfp_quant import mxfp4_fake_quant

    device = 'cuda' if torch.cuda.is_available() else 'cpu'

    x = torch.randn(64, dtype=torch.float32, device=device, requires_grad=True)
    y = mxfp4_fake_quant(x)
    grad_out = torch.randn_like(y)
    y.backward(grad_out)

    assert torch.allclose(x.grad, grad_out, atol=1e-7), \
        f"MXFP4 STE gradient mismatch.\nGot: {x.grad}\nExpected: {grad_out}"
    print("  PASS: MXFP4 STE gradient pass-through verified")


