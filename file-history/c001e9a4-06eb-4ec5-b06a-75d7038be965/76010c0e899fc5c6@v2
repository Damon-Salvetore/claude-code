# Test 5: MXFP4 multi-block quantization
# =====================================================
def test_mxfp4_multi_block():
    """MXFP4 quantization across multiple blocks of 32."""
    from kernel.mxfp_quant import mxfp4_fake_quant, MXFP_BLOCK_SIZE

    device = 'cuda' if torch.cuda.is_available() else 'cpu'

    # 4 blocks of 32 = 128 elements
    x = torch.randn(128, dtype=torch.float32, device=device)
    result = mxfp4_fake_quant(x)

